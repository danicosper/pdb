#Puxando os bancos de dados:
votos2025 <- read.csv(here("data","raw","votacoesVotos-2025.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")
lider2025 <- read.csv(here("data", "raw", "votacoesOrientacoes-2025.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")
votos2024 <- read.csv(here("data","raw","votacoesVotos-2024.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")
lider2024 <- read.csv(here("data", "raw", "votacoesOrientacoes-2024.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")
votos2023 <- read.csv(here("data","raw","votacoesVotos-2023.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")
lider2023 <- read.csv(here("data", "raw", "votacoesOrientacoes-2023.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")

#Vamos unir os bancos de dados para abordar o governo lula em conjunto até 8 de novembro de 2025:
votos <- bind_rows(votos2023,votos2024,votos2025)
lider <- bind_rows(lider2023,lider2024,lider2025)

#Criar a variavel data da votacao
votos <- separate(votos, "dataHoraVoto", c("data", "hora"), sep = "T")

#Criar votacoes validas, ou seja, com quórum de 50%
#50% de 513 deputados é 257
temp <- votos %>%
  filter(voto != "O") %>%
  group_by(idVotacao, data) %>%
  summarize(n = n()) %>%
  mutate(valida = ifelse(as.Date(data) > as.Date("1995-01-31") & n >= 257, 1,0)) %>%
  select(idVotacao, valida)

#juntando esse banco da votacao valida com o de votos
votos <- votos %>%
  left_join(temp, by = "idVotacao")

#transformando os votos em vetores
votos <- votos %>% mutate(voto=recode(votos$voto, "Sim" = "S", "Não" = "N", "Abstenção" = "A"))

# criar votacoes unanimes - criterio da ciencia politica mundial, pois a maior parte das votacoes sao unanimes
#VOTACOES UNANIMES
#criterio: 90% do plenario votou igual (sim ou nao),
# levando em considerao abstencao e desconsiderando obstrucao
temp <- votos %>%
  filter(voto != "O") %>%
  group_by(idVotacao, voto) %>%
  summarize(n = n()) %>%
  spread(key = voto, value = n, fill = 0) %>%
  mutate(unanime = ifelse(S/(A+N+S) >= .9 | N/(A+N+S) >= .9, 1, 0)) %>%
  select(idVotacao, unanime)

votos <- votos %>%
  left_join(temp, by = "idVotacao")

# Indica se a votacao entra na amostra
#ou seja, votacao valida e nao unanime?
votos <- votos %>%
  mutate(amostra = ifelse(valida == 1 & unanime == 0, 1, 0))

#E já vamos filtrar apenas o que entra na amostra
votos <- votos %>%
  filter(amostra == 1)

#Agora vamos transformar em caracter lógico a votacao do lider do governo no banco de dados lider
lider <- lider %>% mutate(lider=recode(lider$orientacao, "Sim" = "S", "Não" = "N", "Liberado" = "L", "Obstrução" = "O"))

#Agora vamos filtrar apenas a orientacao do lider do governo
lider <- lider %>% filter(siglaBancada == "Governo", "GOV")

#Agora vamos criar a variavel de disciplina em relacao ao governo por votacao, adicionando no banco de votos
#a orientacao do governo e depois criando uma variavel testando se o voto é igual a orientacao. Antes disso
#vamos só diminuir o banco lider para não adicionar variáveis a toa e vamos renomear a variavel lider dentro de lider
#pra ficar menos confuso
lider <- lider %>% select(idVotacao, lider)
lider <- lider %>% rename(origoverno = lider)

votos <- votos %>%
  left_join(lider, by = "idVotacao")

#Agora vamos ver o índice de governismo por deputado por partido, vou add também a UF, vamos chamar de discg, que é disciplina em relacao ao governo
votos$discg <- ifelse(votos$voto==votos$origoverno,1,0)

discg <- votos %>%
  filter(amostra == 1) %>%
  group_by(deputado_nome, deputado_siglaPartido, deputado_siglaUf) %>%
  summarize(discg = sum(discg,na.rm=T)/sum(!is.na(discg))*100)

#Agora vamos exportar a tabela
export(discg, here("data", "processed", "governismo_dep_regiao_novembro2025.csv"))

#Agora vou filtrar apenas pelos deputados do PL:
discg <- filter(discg, deputado_siglaPartido == "PL")

#Vou salvar apenas deputados do PL:
export(discg, here("data", "processed", "governismo_depPL_regiao_novembro2025.csv"))

#Vou pedir um gráfico do governismo do PL no governo Lula III:
ggplot(discg, aes(x = discg)) +
  geom_histogram(binwidth = 1, fill = "steelblue", color = "white") +
  labs(title = "Governismo do PL no governo Lula III", x = "% de Governismo", y = "Frequência")


#Agora vou adicionar os seguidores no instagram dos deputados pra ver se tem correlação com governismo:
insta <- read.csv(here("data", "raw", "deputados_seguidores.csv"), header=T, sep=";", fill=T, fileEncoding="UTF-8-BOM")

higieniza_nome <- function(x) {
  x %>%
    enc2utf8() %>%
    stringi::stri_trans_nfc() %>%
    stringr::str_to_lower(locale = "pt_BR") %>%
    stringr::str_squish() %>%
    stringr::str_replace_all("[[:punct:]]", " ") %>%
    stringr::str_squish() %>%
    stringi::stri_trans_general("Latin-ASCII")  # remove acentos (José -> Jose)
}

discg <- discg %>% mutate(deputado_key = higieniza_nome(deputado_nome))
insta <- insta %>% mutate(deputado_key = higieniza_nome(deputado_nome))

dep_insta <- left_join(discg, insta, by = "deputado_key")

#Correlação


# 1) Garantir que as duas colunas são numéricas com decimal "."
dep_insta_num <- dep_insta %>%
  mutate(
    seguidores_insta = parse_number(as.character(seguidores_insta),
                                    locale = locale(decimal_mark = ".", grouping_mark = ",")),
    discg = parse_number(as.character(discg),
                         locale = locale(decimal_mark = ".", grouping_mark = ","))
  )

# 2) Resumo rápido de completude
resumo <- dep_insta_num %>%
  summarise(
    n_total = n(),
    n_completo = sum(complete.cases(seguidores_insta, discg))
  )
print(resumo)

# 3) Correlação de Pearson (coeficiente + teste com p-valor e IC)
pearson_r <- cor(dep_insta_num$seguidores_insta, dep_insta_num$discg,
                 use = "complete.obs", method = "pearson")
cat("Coeficiente de correlação de Pearson (r):", round(pearson_r, 3), "\n")

pearson_test <- cor.test(dep_insta_num$seguidores_insta, dep_insta_num$discg,
                         use = "complete.obs", method = "pearson")
print(pearson_test)

# 4) (Opcional) Gráfico de dispersão com linha de tendência linear
ggplot(dep_insta_num, aes(x = seguidores_insta, y = discg)) +
  geom_point(alpha = 0.6) +
