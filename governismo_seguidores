##Agora o grafico>

lot_spearman <- function(df,
                         x = "seguidores_insta",
                         y = "discg",
                         remove_outlier_value = NULL,   # ex.: 200000
                         remove_outlier_name = NULL,    # ex.: "Fulano de Tal"
                         name_col = "deputado_nome",
                         log_scale = FALSE) {
  d <- df
  
  # Remove outlier por valor (na variável x)
  if (!is.null(remove_outlier_value)) {
    d <- d %>% filter(.data[[x]] != remove_outlier_value)
  }
  
  # Remove outlier por nome (se houver essa coluna)
  if (!is.null(remove_outlier_name) && name_col %in% names(d)) {
    d <- d %>% filter(.data[[name_col]] != remove_outlier_name)
  }
  
  # Cálculo de Spearman
  if (log_scale) {
    mask <- d[[x]] > 0 & d[[y]] > 0
    st <- cor.test(
      log10(d[[x]][mask]),
      log10(d[[y]][mask]),
      use = "complete.obs", method = "spearman", exact = FALSE
    )
    rho  <- unname(st$estimate); pval <- st$p.value
    p <- ggplot(d, aes(x = .data[[x]] + 1, y = .data[[y]] + 1)) +
      geom_point(alpha = 0.6) +
      geom_smooth(method = "loess", se = TRUE, color = "steelblue") +
      scale_x_log10(labels = label_number(big.mark = ",", decimal.mark = ".")) +
      scale_y_log10(labels = label_number(big.mark = ",", decimal.mark = ".")) +
      labs(
        title = sprintf("Escala log10 — Spearman ρ = %.3f (p = %.2g)", rho, pval),
        x = paste0(x, " (log10)"), y = paste0(y, " (log10)")
      ) +
      theme_minimal()
  } else {
    st <- cor.test(
      d[[x]], d[[y]],
      use = "complete.obs", method = "spearman", exact = FALSE
    )
    rho  <- unname(st$estimate); pval <- st$p.value
    p <- ggplot(d, aes(x = .data[[x]], y = .data[[y]])) +
      geom_point(alpha = 0.6) +
      geom_smooth(method = "loess", se = TRUE, color = "tomato") +
      scale_x_continuous(labels = label_number(big.mark = ",", decimal.mark = ".")) +
      scale_y_continuous(labels = label_number(big.mark = ",", decimal_mark = ".")) +
      labs(
        title = sprintf("Spearman ρ = %.3f (p = %.2g)", rho, pval),
        x = x, y = y
      ) +
      theme_minimal()
  }
  
  return(p)
}


